</header>

<div class="drawer-overlay" id="overlay" onclick="toggleMenu()"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header"><span class="close-drawer" onclick="toggleMenu()">&times;</span></div>
    <nav class="drawer-nav">
        <a href="/" onclick="toggleMenu()">Home</a>
        <a href="/collections/all" onclick="toggleMenu()">Shop</a>
        <a href="#" onclick="toggleMenu()">About</a>
        <a href="/account" onclick="toggleMenu()">Account</a>
    </nav>
</div>

<main class="collection-section">
    <div class="collection-header">
        <h1>Our Collection</h1>
        <p>Traditional herbal solutions for your digestive well-being.</p>
    </div>

    <div class="product-grid">
        {% for product in collection.products %}
        <div class="product-card">
            {% if forloop.first %}<span class="badge">Bestseller</span>{% endif %}
            <div class="product-image">
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}">
            </div>
            <div class="product-info">
                <h3><a href="{{ product.url }}" style="text-decoration: none; color: inherit;">{{ product.title }}</a></h3>
                <p class="product-meta">250g | 100% Herbal</p>
                <div class="price">{{ product.price | money }}</div>
                <a href="{{ product.url }}" class="cta-button">View Details</a>
            </div>
        </div>
        {% else %}
        <div class="product-card">
            <span class="badge">Bestseller</span>
            <div class="product-image">
                <img src="{{ 'Natural Stomach Relief Phaki.png' | asset_img_url: '600x' }}" alt="Natural Stomach Relief Phaki">
            </div>
            <div class="product-info">
                <h3>Natural Stomach Relief Phaki</h3>
                <p class="product-meta">250g | 100% Herbal</p>
                <div class="price">Rs. 890.00</div>
                <a href="/products/natural-stomach-relief-phaki" class="cta-button">View Details</a>
            </div>
        </div>
        {% endfor %}
    </div>
</main>

