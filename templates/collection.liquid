{% comment %}
  Noor E Shifa - Collection Template
  100% fidelity with collection.html
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b;
        --secondary: #7a1c1c;
        --background: #f5f5f5;
        --announcement: #333333;
        --accent: #E8F3F1;
        --text: #333333;
        --white: #FFFFFF;
        --border: #e0e0e0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body { font-family: var(--font-sans); background-color: var(--background); color: var(--text); line-height: 1.6; }

    /* Announcement Bar */
    .announcement-bar {
        background-color: var(--announcement);
        color: var(--white);
        text-align: center;
        padding: 8px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Header */
    header {
        background-color: var(--background);
        padding: 20px 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0, 33, 71, 0.1);
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        text-decoration: none;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-weight: 700;
        letter-spacing: 2px;
        white-space: nowrap;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        margin-right: 25px;
        text-transform: uppercase;
    }

    .header-icons { display: flex; gap: 20px; align-items: center; }

    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1001; }
    .menu-toggle span { display: block; width: 25px; height: 2px; background-color: var(--primary); transition: 0.3s; }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 80%; height: 100%;
        background-color: var(--white); z-index: 2000; transition: 0.4s ease-in-out;
        box-shadow: 10px 0 30px rgba(0,0,0,0.1); padding: 40px 30px; display: flex; flex-direction: column;
    }
    .mobile-drawer.active { left: 0; }
    .drawer-header { display: flex; justify-content: flex-end; margin-bottom: 40px; }
    .close-drawer { font-size: 32px; cursor: pointer; color: var(--primary); }
    .drawer-nav { display: flex; flex-direction: column; gap: 25px; }
    .drawer-nav a {
        text-decoration: none;
        color: var(--primary);
        font-size: 22px;
        font-family: var(--font-serif);
        font-weight: 700;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(26,59,43,0.1);
        padding-bottom: 15px;
    }
    .drawer-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1999; display: none; }
    .drawer-overlay.active { display: block; }

    /* Collection Section */
    .collection-section { padding: 60px 5% 100px; max-width: 1200px; margin: 0 auto; }
    .collection-header { text-align: center; margin-bottom: 60px; }
    .collection-header h1 { font-family: var(--font-serif); font-size: 48px; color: var(--primary); margin-bottom: 15px; }
    .collection-header p { font-size: 18px; color: #666; }

    /* Product Grid */
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 40px; justify-items: center; }

    .product-card {
        width: 100%; max-width: 420px;
        background: var(--white);
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        transition: transform 0.3s;
        position: relative;
    }
    .product-card:hover { transform: translateY(-8px); }

    .badge {
        display: inline-block;
        background-color: var(--secondary);
        color: white;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 12px;
        letter-spacing: 0.5px;
    }

    .product-image { width: 100%; height: 380px; margin-bottom: 20px; border-radius: 8px; overflow: hidden; }
    .product-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .product-info h3 { font-family: var(--font-serif); font-size: 22px; margin-bottom: 8px; color: var(--primary); }
    .product-meta { font-size: 14px; color: #777; margin-bottom: 10px; }
    .price { font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 18px; }

    .cta-button {
        display: block;
        background-color: var(--primary);
        color: #FFFFFF !important;
        padding: 15px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        text-transform: uppercase;
        border-radius: 40px;
        text-align: center;
        letter-spacing: 1px;
        transition: background-color 0.3s, transform 0.2s;
    }
    .cta-button:hover { background-color: #244d38; transform: translateY(-2px); }

    /* Footer */
    footer { background-color: var(--primary); color: var(--white); padding: 80px 5% 40px; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px; }
    .footer-brand h2 { font-family: var(--font-serif); font-size: 28px; margin-bottom: 20px; }
    .footer-brand p { font-size: 14px; opacity: 0.7; line-height: 1.7; }
    .social-links { display: flex; gap: 20px; margin-top: 20px; }
    .footer-column h3 { font-size: 12px; text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1px; }
    .footer-column ul { list-style: none; }
    .footer-column ul li { margin-bottom: 12px; }
    .footer-column ul li a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: opacity 0.3s; }
    .footer-column ul li a:hover { opacity: 1; color: white; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 20px; }
    .newsletter-form input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 40px; color: white; flex: 1; font-size: 14px; }
    .newsletter-form button { background: var(--white); color: var(--primary); border: none; padding: 12px 25px; border-radius: 40px; font-weight: 700; cursor: pointer; }
    .footer-bottom { margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; font-size: 12px; opacity: 0.5; }

    /* Responsive */
    @media (max-width: 768px) {
        .menu-toggle { display: flex !important; }
        nav { display: none !important; }
        header { padding: 12px 5%; }
        .logo { font-size: 18px; white-space: nowrap; }
        .header-icons { gap: 12px; }
        .collection-header h1 { font-size: 32px; }
        .product-grid { grid-template-columns: 1fr; gap: 20px; }
        .footer-container { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .social-links { justify-content: center; margin-top: 25px; }
        .newsletter-form { flex-direction: column; }
    }
</style>

<div class="announcement-bar">Free Shipping on Orders Above Rs. 3000</div>

