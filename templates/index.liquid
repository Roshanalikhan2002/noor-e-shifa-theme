<style>
    :root {
        --primary: #1a3b2b; /* Deep Herbal Green */
        --secondary: #d4a373; /* Earthy Gold/Sand */
        --accent: #f4f1de; /* Creamy Paper */
        --text: #2c3e50;
        --white: #ffffff;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: var(--font-sans);
        color: var(--text);
        background-color: var(--accent);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Announcement Bar */
    .announcement-bar {
        background-color: #333;
        color: white;
        text-align: center;
        padding: 10px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    /* Navigation */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 5%;
        background-color: var(--white);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        margin: 0 15px;
        letter-spacing: 1px;
    }

    .header-icons {
        display: flex;
        gap: 20px;
    }

    .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        z-index: 1001;
    }

    .menu-toggle span {
        display: block;
        width: 25px;
        height: 2px;
        background-color: var(--primary);
        transition: 0.3s;
    }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        height: 100%;
        background-color: var(--white);
        z-index: 2000;
        transition: 0.4s ease-in-out;
        box-shadow: 10px 0 30px rgba(0,0,0,0.1);
        padding: 40px 30px;
        display: flex;
        flex-direction: column;
    }

    .mobile-drawer.active {
        left: 0;
    }

    .drawer-header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 40px;
    }

    .close-drawer {
        font-size: 32px;
        cursor: pointer;
        color: var(--primary);
    }

    .drawer-nav {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .drawer-nav a {
        text-decoration: none;
        color: var(--primary);
        font-size: 20px;
        font-family: var(--font-serif);
        font-weight: 700;
        text-transform: uppercase;
    }

    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1999;
        display: none;
    }

    .drawer-overlay.active {
        display: block;
    }

    /* Hero Section */
    .hero {
        display: flex;
        flex-direction: row-reverse; /* Image on the right for desktop */
        height: 90vh;
        align-items: center;
        background-color: var(--accent);
        overflow: hidden;
    }

    .hero-content {
        flex: 1;
        padding: 0 8%;
    }

    .hero-content h1 {
        font-family: var(--font-serif);
        font-size: 64px;
        color: var(--primary);
        line-height: 1.1;
        margin-bottom: 30px;
    }

    .hero-content p {
        font-size: 18px;
        max-width: 450px;
        margin-bottom: 30px;
    }

    .cta-button {
        display: inline-block;
        background-color: var(--primary);
        color: #FFFFFF !important; /* Force white for visibility */
        padding: 18px 40px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        text-transform: uppercase;
        border-radius: 40px;
        transition: opacity 0.3s;
        letter-spacing: 1px;
    }

    .cta-button:hover {
        opacity: 0.9;
    }

    .hero-image {
        flex: 1;
        height: 100%;
        overflow: hidden;
    }

    .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Featured Product */
    .featured-product {
        padding: 100px 5%;
        text-align: center;
    }

    .featured-product h2 {
        font-family: var(--font-serif);
        font-size: 42px;
        color: var(--primary);
        margin-bottom: 50px;
    }

    .product-card {
        max-width: 400px;
        margin: 0 auto;
        background: var(--white);
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: transform 0.3s;
    }

    .product-card:hover {
        transform: translateY(-10px);
    }

    .product-image {
        width: 100%;
        height: 400px; /* Fixed height for consistency */
        margin-bottom: 20px;
        border-radius: 40px;
        overflow: hidden;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-title {
        font-family: var(--font-serif);
        font-size: 24px;
        margin-bottom: 10px;
    }

    .price {
        font-size: 20px;
        color: var(--secondary);
        font-weight: 700;
        margin-bottom: 20px;
    }

    /* Features Section */
    .features {
        display: flex;
        justify-content: space-around;
        padding: 100px 5%;
        background-color: var(--white);
    }

    .feature-item {
        text-align: center;
        max-width: 300px;
    }

    .feature-item h4 {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        margin-bottom: 15px;
    }

    /* Modern Footer */
    footer {
        background-color: var(--primary);
        color: var(--white);
        padding: 80px 5% 40px;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 60px;
    }

    .footer-brand h2 {
        font-family: var(--font-serif);
        margin-bottom: 20px;
    }

    .social-links {
        display: flex;
        gap: 20px;
        margin-top: 20px;
    }

    .footer-column h3 {
        font-size: 14px;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 1px;
    }

    .footer-column ul {
        list-style: none;
    }

    .footer-column ul li {
        margin-bottom: 12px;
    }

    .footer-column ul li a {
        color: var(--white);
        text-decoration: none;
        font-size: 14px;
        opacity: 0.7;
        transition: opacity 0.3s;
    }

    .footer-column ul li a:hover {
        opacity: 1;
    }

    .newsletter-form {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .newsletter-form input {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 12px;
        border-radius: 40px;
        color: white;
        flex: 1;
        font-size: 14px;
    }

    .newsletter-form button {
        background: var(--white);
        color: var(--primary);
        border: none;
        padding: 0 20px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
    }

    .footer-bottom {
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid rgba(255,255,255,0.1);
        text-align: center;
        font-size: 12px;
        opacity: 0.5;
    }

    /* Responsive */
    @media (max-width: 768px) {
        header {
            padding: 15px 5%;
            justify-content: space-between;
            position: relative;
        }
        .menu-toggle {
            display: flex;
        }
        nav {
            display: none; /* Hide desktop nav */
        }
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 20px;
            margin-bottom: 0;
        }
        .header-icons {
            gap: 15px;
            font-size: 12px;
        }
        .hero {
            flex-direction: column; /* Normal column for mobile: image (first) on top */
            height: auto;
        }
        .hero-image {
            width: 100%;
            height: 350px;
            order: -1;
        }
        .hero-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .hero-content {
            padding: 40px 5%;
            text-align: center;
        }
        .hero-content h1 {
            font-size: 28px;
        }
        .footer-container {
            grid-template-columns: 1fr;
            gap: 30px;
            text-align: center;
        }
        .social-links {
            justify-content: center;
            margin-top: 25px;
        }
        .features {
            flex-direction: column;
            padding: 60px 5%;
            gap: 50px;
            text-align: center;
        }
        .feature-item {
            max-width: 100%;
            margin: 0 auto;
        }
        .feature-item h4 {
            font-size: 24px;
            margin-bottom: 10px;
        }
    }
</style>

