{% comment %}
  Noor E Shifa - Homepage Template
  Converted from static HTML
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b; /* Deep Herbal Green */
        --secondary: #7a1c1c; /* Burgundy/Red */
        --background: #f5f5f5; /* Light Grey/Beige */
        --announcement: #333333; /* Charcoal */
        --accent: #E8F3F1; /* Soft mint accent */
        --text: #333333;
        --white: #ffffff;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
        --blume-bg: #FAF5EF;
        --blume-navy: #12314E;
    }

    .hollow-heading {
        font-family: var(--font-serif);
        font-size: clamp(40px, 8vw, 80px);
        color: transparent;
        -webkit-text-stroke: 1px var(--blume-navy);
        text-align: center;
        text-transform: uppercase;
        margin-bottom: 40px;
        letter-spacing: 2px;
    }

    .section-container {
        padding: 80px 5%;
        background-color: var(--blume-bg);
    }

    /* Shop by Concern Styles */
    .concern-slider {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        padding-bottom: 20px;
        scroll-snap-type: x mandatory;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .concern-slider::-webkit-scrollbar { display: none; }

    .concern-card {
        flex: 0 0 300px;
        aspect-ratio: 4/5;
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        scroll-snap-align: start;
        cursor: pointer;
    }
    .concern-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s;
    }
    .concern-card:hover img { transform: scale(1.05); }
    .concern-card-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 30px;
        background: linear-gradient(transparent, rgba(0,0,0,0.4));
        color: white;
    }
    .concern-card-title {
        font-family: var(--font-serif);
        font-size: 24px;
        font-weight: 700;
    }

    /* Best Sellers Slider Styles */
    .best-sellers-section {
        background-color: var(--blume-bg);
        padding: 100px 5%;
    }
    .product-slider {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
    }
    .product-slider::-webkit-scrollbar { display: none; }
    
    .product-item {
        flex: 0 0 calc(25% - 18px);
        scroll-snap-align: start;
        text-decoration: none;
        color: var(--blume-navy);
    }
    @media (max-width: 1024px) { .product-item { flex: 0 0 calc(50% - 12px); } }
    @media (max-width: 600px) { .product-item { flex: 0 0 80%; } }

    .product-item-img {
        width: 100%;
        aspect-ratio: 1;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .product-item-img img { width: 100%; height: 100%; object-fit: cover; }
    
    .product-item-info { text-align: left; }
    .product-item-title { font-weight: 700; font-size: 16px; margin-bottom: 5px; }
    .product-item-rating { color: var(--blume-navy); font-size: 14px; margin-bottom: 5px; }

    /* Expert Section Styles */
    .expert-section {
        display: flex;
        align-items: center;
        background-color: #ffffff;
        padding: 100px 8%;
        gap: 60px;
    }
    @media (max-width: 768px) {
        .expert-section { flex-direction: column; text-align: center; padding: 60px 5%; }
    }
    .expert-content { flex: 1; }
    .expert-quote {
        font-family: var(--font-serif);
        font-size: clamp(24px, 4vw, 36px);
        color: var(--blume-navy);
        line-height: 1.2;
        margin-bottom: 30px;
        font-style: italic;
    }
    .expert-name { font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--blume-navy); }
    .expert-title { font-size: 14px; color: #666; }
    .expert-image { flex: 1; border-radius: 20px; overflow: hidden; box-shadow: 20px 20px 0 var(--blume-bg); }
    .expert-image img { width: 100%; display: block; }

    /* Founder Home Section */
    .founder-home-section {
        background-color: #ffffff;
        padding: 100px 5%;
        display: flex;
        align-items: center;
        gap: 80px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .founder-home-image {
        flex: 1;
        border-radius: 20px;
        overflow: hidden;
        aspect-ratio: 1;
        box-shadow: 20px 20px 0 var(--blume-bg);
    }

    .founder-home-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .founder-home-content {
        flex: 1.2;
    }

    .founder-home-content .label {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
        font-size: 12px;
        color: var(--secondary);
        margin-bottom: 20px;
        display: block;
    }

    .founder-home-content h2 {
        font-family: var(--font-serif);
        font-size: 42px;
        line-height: 1.2;
        margin-bottom: 30px;
        color: var(--primary);
    }

    .founder-home-content p {
        font-size: 18px;
        color: #555;
        margin-bottom: 30px;
        line-height: 1.7;
    }

    .founder-home-content .quote {
        font-style: italic;
        border-left: 3px solid var(--secondary);
        padding-left: 20px;
        margin-bottom: 30px;
        font-size: 20px;
        color: var(--primary);
    }

    @media (max-width: 768px) {
        .founder-home-section {
            flex-direction: column;
            padding: 60px 5%;
            gap: 40px;
            text-align: center;
        }
        .founder-home-image {
            width: 100%;
            max-width: 400px;
        }
        .founder-home-content .quote {
            text-align: left;
        }
    }

    /* Review Styles */
    .reviews-section {
        background-color: var(--blume-bg);
        padding: 100px 5%;
        text-align: center;
    }
    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-top: 50px;
    }
    .review-card {
        background: white;
        padding: 40px;
        border-radius: 16px;
        text-align: left;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }
    .review-stars { color: var(--blume-navy); margin-bottom: 20px; font-size: 20px; }
    .review-text { font-size: 15px; color: #444; line-height: 1.8; margin-bottom: 25px; }
    .review-author { display: flex; align-items: center; gap: 12px; }
    .review-author-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; }
    .review-author-name { font-weight: 700; font-size: 14px; }
    .review-ba-img { width: 100%; border-radius: 12px; margin-bottom: 20px; }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: var(--font-sans);
        color: var(--text);
        background-color: var(--background);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Announcement Bar */
    .announcement-bar {
        background-color: #333;
        color: white;
        text-align: center;
        padding: 10px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    /* Navigation */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 5%;
        background-color: var(--white);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        margin: 0 15px;
        letter-spacing: 1px;
    }

    .header-icons {
        display: flex;
        gap: 20px;
    }

    .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        z-index: 1001;
    }

    .menu-toggle span {
        display: block;
        width: 25px;
        height: 2px;
        background-color: var(--primary);
        transition: 0.3s;
    }

    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 300px; height: 100%;
        background-color: #ffffff; z-index: 2000; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0; display: flex; flex-direction: column;
        box-shadow: 10px 0 40px rgba(0,0,0,0.15);
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-banner {
        background-color: var(--primary);
        padding: 40px 25px;
        color: #FFFFFF;
    }
    .drawer-banner h2 { font-family: var(--font-serif); font-size: 24px; margin: 0; letter-spacing: 1px; }
    .drawer-banner p { font-size: 13px; opacity: 0.8; margin-top: 5px; font-weight: 400; }

    .drawer-nav { 
        padding: 15px 0; 
        flex-grow: 1; 
        overflow-y: auto; 
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        padding: 14px 25px;
        text-decoration: none;
        color: #444;
        font-weight: 600;
        font-size: 15px;
        gap: 20px;
        transition: all 0.2s;
    }
    .drawer-link:hover { 
        background-color: #f9f9f9; 
        color: var(--primary); 
    }
    .drawer-link.active { 
        background-color: #e8f3f1; 
        color: var(--primary); 
    }
    .drawer-link svg { 
        width: 22px; 
        height: 22px; 
        color: #666;
        transition: color 0.2s;
    }
    .drawer-link:hover svg { color: var(--primary); }

    .drawer-divider {
        height: 1px;
        background-color: #eee;
        margin: 10px 0;
    }

    .drawer-group-label {
        padding: 20px 25px 10px;
        font-size: 12px;
        text-transform: uppercase;
        color: #999;
        font-weight: 700;
        letter-spacing: 1.5px;
    }

    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1999;
        display: none;
    }
    .drawer-overlay.active { display: block; }

    /* Hero Section */
    .hero {
        width: 100%;
        height: auto;
        background-color: var(--accent);
        overflow: hidden;
    }

    .hero-content {
        display: none; /* Hidden as per request to show full banner */
    }

    .hero-content h1 {
        font-family: var(--font-serif);
        font-size: 64px;
        color: var(--primary);
        line-height: 1.1;
        margin-bottom: 30px;
    }

    .hero-content p {
        font-size: 18px;
        max-width: 450px;
        margin-bottom: 30px;
    }

    .cta-button {
        display: inline-block;
        background-color: var(--primary);
        color: #FFFFFF !important; /* Force white for visibility */
        padding: 18px 40px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        text-transform: uppercase;
        border-radius: 40px;
        transition: opacity 0.3s;
        letter-spacing: 1px;
    }

    .cta-button:hover {
        opacity: 0.9;
    }

    .hero-image {
        width: 100%;
        height: auto;
        overflow: hidden;
    }

    .hero-image img {
        width: 100%;
        height: auto;
        display: block;
    }

    .mobile-slider { display: none; }

    /* Featured Product */
    .featured-product {
        padding: 100px 5%;
        text-align: center;
    }

    .featured-product h2 {
        font-family: var(--font-serif);
        font-size: 42px;
        color: var(--primary);
        margin-bottom: 50px;
    }

    .product-card {
        max-width: 400px;
        margin: 0 auto;
        background: var(--white);
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: transform 0.3s;
    }

    .product-card:hover {
        transform: translateY(-10px);
    }

    .product-image {
        width: 100%;
        height: 400px; /* Fixed height for consistency */
        margin-bottom: 20px;
        border-radius: 40px;
        overflow: hidden;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-title {
        font-family: var(--font-serif);
        font-size: 24px;
        margin-bottom: 10px;
    }

    .price {
        font-size: 20px;
        color: var(--secondary);
        font-weight: 700;
        margin-bottom: 20px;
    }

    /* Features Section */
    .features {
        display: flex;
        justify-content: space-around;
        padding: 100px 5%;
        background-color: var(--white);
    }

    .feature-item {
        text-align: center;
        max-width: 300px;
    }

    .feature-item h4 {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        margin-bottom: 15px;
    }

    /* Modern Footer */
    footer {
        background-color: var(--primary);
        color: var(--white);
        padding: 80px 5% 40px;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 60px;
    }

    .footer-brand h2 {
        font-family: var(--font-serif);
        margin-bottom: 20px;
    }

    .social-links {
        display: flex;
        gap: 20px;
        margin-top: 20px;
    }

    .footer-column h3 {
        font-size: 14px;
        text-transform: uppercase;
        margin-bottom: 25px;
        letter-spacing: 1px;
    }

    .footer-column ul {
        list-style: none;
    }

    .footer-column ul li {
        margin-bottom: 12px;
    }

    .footer-column ul li a {
        color: var(--white);
        text-decoration: none;
        font-size: 14px;
        opacity: 0.7;
        transition: opacity 0.3s;
    }

    .footer-column ul li a:hover {
        opacity: 1;
    }

    .newsletter-form {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .newsletter-form input {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 12px;
        border-radius: 40px;
        color: white;
        flex: 1;
        font-size: 14px;
    }

    .newsletter-form button {
        background: var(--white);
        color: var(--primary);
        border: none;
        padding: 0 20px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
    }

    .footer-bottom {
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid rgba(255,255,255,0.1);
        text-align: center;
        font-size: 12px;
        opacity: 0.5;
    }

    /* Responsive */
    @media (max-width: 768px) {
        header {
            padding: 15px 5%;
            justify-content: space-between;
            position: relative;
        }
        .menu-toggle {
            display: flex;
        }
        nav {
            display: none; /* Hide desktop nav */
        }
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 20px;
            margin-bottom: 0;
        }
        .header-icons {
            gap: 15px;
            font-size: 12px;
        }
        .hero {
            height: auto;
        }
        .hero-image {
            display: none !important;
        }
        .mobile-slider { 
            display: block !important; 
            width: 100%; 
            height: auto; 
            overflow: hidden; 
            position: relative; 
        }
        .slider-wrapper { 
            display: flex; 
            height: 100%; 
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .slide { min-width: 100%; height: auto; }
        .slide img { width: 100%; height: auto; display: block; }
        .hero-content {
            display: none;
        }
        .footer-container {
            grid-template-columns: 1fr;
            gap: 30px;
            text-align: center;
        }
        .social-links {
            justify-content: center;
            margin-top: 25px;
        }
        .features {
            flex-direction: column;
            padding: 60px 5%;
            gap: 50px;
            text-align: center;
        }
        .feature-item {
            max-width: 100%;
            margin: 0 auto;
        }
        .feature-item h4 {
            font-size: 24px;
            margin-bottom: 10px;
        }
    }
</style>

