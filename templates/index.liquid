<script>
    function toggleMenu() {
        const drawer = document.getElementById('mobileDrawer');
        const overlay = document.getElementById('overlay');
        drawer.classList.toggle('active');
        overlay.classList.toggle('active');
    }

    // === HOME MOBILE SLIDER ===
    let currentHomeSlide = 0;
    const homeSlides = document.querySelectorAll('#homeMobileSlider .slide');
    if (homeSlides.length > 0) {
        setInterval(() => {
            currentHomeSlide = (currentHomeSlide + 1) % homeSlides.length;
            const wrapper = document.getElementById('homeMobileSlider');
            if (wrapper) {
                wrapper.style.transform = `translateX(-${currentHomeSlide * 100}%)`;
            }
        }, 3000);
    }
</script>
