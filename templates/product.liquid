{% comment %}
  Noor E Shifa - 100% Fidelity Product Template
  Synced exactly with product-page.html
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b; /* Deep Herbal Green */
        --secondary: #7a1c1c; /* Burgundy/Red */
        --background: #ffffff; /* Pure White */
        --announcement: #333333; /* Charcoal */
        --accent: #E8F3F1;
        --text: #333333;
        --white: #FFFFFF;
        --border: #e0e0e0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--text);
        line-height: 1.6;
    }

    /* Announcement Bar */
    .announcement-bar {
        background-color: var(--announcement);
        color: var(--white);
        text-align: center;
        padding: 8px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Header */
    header {
        background-color: var(--background);
        padding: 20px 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0, 33, 71, 0.1);
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        text-decoration: none;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-weight: 700;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        margin-right: 25px;
        text-transform: uppercase;
    }

    .header-icons { display: flex; gap: 20px; }

    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1001; }
    .menu-toggle span { display: block; width: 25px; height: 2px; background-color: var(--primary); }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 80%; height: 100%;
        background-color: var(--white); z-index: 2000; transition: 0.4s ease-in-out;
        box-shadow: 10px 0 30px rgba(0,0,0,0.1); padding: 40px 30px;
        display: flex; flex-direction: column;
    }
    .mobile-drawer.active { left: 0; }
    .drawer-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.5); z-index: 1999; display: none;
    }
    .drawer-overlay.active { display: block; }

    /* Product Main Section */
    .product-main { display: flex; padding: 60px 5%; gap: 60px; max-width: 1400px; margin: 0 auto; }
    .product-gallery { flex: 1.2; }
    .main-image { width: 100%; height: 600px; background-color: var(--white); border-radius: 8px; overflow: hidden; }
    .main-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .product-details { flex: 1; }
    .product-details h1 { font-family: var(--font-serif); font-size: 48px; color: var(--primary); line-height: 1.2; margin-bottom: 10px; }
    .subtitle { font-size: 18px; color: #666; margin-bottom: 20px; }
    .description { font-size: 16px; color: #444; margin-bottom: 30px; max-width: 500px; }
    .price-section { margin-bottom: 30px; }
    .price { font-size: 28px; font-weight: 600; color: var(--primary); }

    .add-to-cart-container { margin-bottom: 40px; }
    .atc-btn {
        width: 100%; background-color: var(--primary); color: #FFFFFF !important;
        padding: 18px; border: none; border-radius: 40px; font-weight: 700;
        font-size: 16px; text-transform: uppercase; cursor: pointer;
        margin-bottom: 20px; letter-spacing: 1.5px;
        transition: transform 0.2s, background-color 0.2s;
        box-shadow: 0 4px 15px rgba(26, 59, 43, 0.2);
    }

    /* Accordion Style */
    .accordion { border-top: 1px solid var(--border); }
    .accordion-item { border-bottom: 1px solid var(--border); }
    .accordion-header {
        width: 100%; padding: 15px 0; background: none; border: none;
        display: flex; justify-content: space-between; align-items: center;
        font-weight: 600; font-size: 14px; text-transform: uppercase;
        cursor: pointer; color: var(--primary);
    }
    .accordion-content { padding-bottom: 15px; font-size: 14px; color: #555; display: none; }
    .accordion-item.active .accordion-content { display: block; }

    /* Spotted on You Section */
    .spotted-section { padding: 80px 5%; text-align: center; background-color: #ffffff; }
    .spotted-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .spotted-item img { width: 100%; border-radius: 8px; transition: transform 0.3s; }

    /* Plate Section */
    .plate-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; }
    .plate-content { flex: 1; }
    .plate-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .plate-image img { width: 100%; height: 100%; object-fit: cover; }
    .plate-table { width: 100%; border-collapse: collapse; margin-top: 30px; }
    .plate-table td { padding: 15px 0; border-bottom: 1px solid #eee; }
    .plate-table td.label { font-weight: 700; color: var(--primary); width: 120px; }

    /* What's Inside */
    .inside-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; background-color: #ffffff; }
    .inside-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .inside-image img { width: 100%; height: 100%; object-fit: cover; }
    .inside-content { flex: 1; }

    /* FAQ */
    .faq-section { display: flex; padding: 100px 5%; gap: 60px; background-color: #faf9f6; align-items: center; }
    .faq-content { flex: 1; }
    .faq-image { flex: 1; border-radius: 12px; overflow: hidden; height: 600px; }
    .faq-image img { width: 100%; height: 100%; object-fit: cover; }
    .faq-item { border-bottom: 1px solid #ddd; padding: 20px 0; }
    .faq-question { font-weight: 600; font-size: 15px; color: #333; display: flex; justify-content: space-between; cursor: pointer; }
    .faq-answer { font-size: 14px; color: #666; display: none; padding-top: 10px; }

    /* Reviews */
    .reviews-section { padding: 100px 5%; background-color: #ffffff; }
    .review-card { display: flex; padding: 40px 0; border-bottom: 1px solid #eee; gap: 40px; }
    .reviewer-info { width: 150px; }
    .review-content { flex: 1; }

    /* Footer */
    footer { background-color: var(--primary); color: var(--white); padding: 80px 5% 40px; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 60px; }
    .social-links { display: flex; gap: 20px; margin-top: 20px; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 20px; }
    .newsletter-form input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 40px; color: white; flex: 1; }
    .newsletter-form button { background: var(--white); color: var(--primary); border: none; padding: 12px 25px; border-radius: 40px; font-weight: 700; cursor: pointer; }

    @media (max-width: 768px) {
        .logo { font-size: 20px; }
        .product-main, .plate-section, .inside-section, .faq-section { flex-direction: column; padding: 40px 5%; }
        .product-gallery, .plate-image, .inside-image, .faq-image { width: 100%; height: 350px; order: -1; }
        .footer-container { grid-template-columns: 1fr; text-align: center; }
        .social-links { justify-content: center; }
    }
</style>

<div class="announcement-bar">Free Shipping on Orders Above Rs. 3000</div>

<header>
    <div class="menu-toggle" onclick="toggleMenu()"><span></span><span></span><span></span></div>
    <nav><a href="/collections/all">Shop</a><a href="#">About</a></nav>
    <a href="/" class="logo">NOOR E SHIFA</a>
    <div class="header-icons">
        <a href="/search" style="color: var(--primary);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg></a>
        <a href="/cart" style="color: var(--primary);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg><span>({{ cart.item_count }})</span></a>
    </div>
</header>

<div class="drawer-overlay" id="overlay" onclick="toggleMenu()"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <nav class="drawer-nav">
        <a href="/">Home</a>
        <a href="/collections/all">Shop</a>
    </nav>
</div>

<main>
    <section class="product-main">
        <div class="product-gallery">
            <div class="main-image">
                <img src="{{ product.featured_image | img_url: '1000x' }}" alt="{{ product.title }}">
            </div>
        </div>
        <div class="product-details">
            <h1>{{ product.title }}</h1>
            <p class="subtitle">Complete Digestive Balance</p>
            <div class="description">{{ product.description }}</div>
            <div class="price-section"><span class="price">{{ product.price | money }}</span></div>
            <div class="add-to-cart-container">
                <form action="/cart/add" method="post">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="atc-btn">Add to Cart</button>
                </form>
                <div class="accordion">
                    <div class="accordion-item">
                        <button class="accordion-header" onclick="toggleAccordion(this)">Benefits <span>+</span></button>
                        <div class="accordion-content"><ul style="padding-left: 20px;"><li>Instant relief from bloating and acidity.</li><li>Improves gut health and metabolism.</li><li>100% natural and safe.</li></ul></div>
                    </div>
                    <div class="accordion-item">
                        <button class="accordion-header" onclick="toggleAccordion(this)">Application <span>+</span></button>
                        <div class="accordion-content"><p>Take 1/2 teaspoon after meals with lukewarm water. Use twice daily.</p></div>
                    </div>
                    <div class="accordion-item">
                        <button class="accordion-header" onclick="toggleAccordion(this)">Trick <span>+</span></button>
                        <div class="accordion-content"><p>For chronic acidity, take with a squeeze of lemon. Post-dinner ritual works best.</p></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="spotted-section">
        <h2>Spotted on You</h2>
        <div class="spotted-grid">
            <div class="spotted-item"><img src="{{ 'lifestyle_herbal_1.png' | asset_img_url: '600x' }}" alt="S1"></div>
            <div class="spotted-item"><img src="{{ 'lifestyle_herbal_2.png' | asset_img_url: '600x' }}" alt="S2"></div>
            <div class="spotted-item"><img src="{{ 'lifestyle_herbal_3.png' | asset_img_url: '600x' }}" alt="S3"></div>
            <div class="spotted-item"><img src="{{ 'lifestyle_herbal_4.png' | asset_img_url: '600x' }}" alt="S4"></div>
        </div>
    </section>

    <section class="plate-section">
        <div class="plate-content">
            <h2>Wake Up to a Light, Refreshed You.</h2>
            <table class="plate-table">
                <tr><td class="label">Good For:</td><td>Indigestion, Bloating, Acidity</td></tr>
                <tr><td class="label">Feels Like:</td><td>Gentle, cooling relief</td></tr>
                <tr><td class="label">Smells Like:</td><td>Refreshing mix of Cumin and Mint</td></tr>
                <tr><td class="label">FYI:</td><td>100% Herbal • Handmade</td></tr>
            </table>
        </div>
        <div class="plate-image"><img src="{{ 'product_plate.png' | asset_img_url: '800x' }}" alt="Plate"></div>
    </section>

    <section class="inside-section">
        <div class="inside-image"><img src="{{ 'whats_inside.png' | asset_img_url: '800x' }}" alt="Inside"></div>
        <div class="inside-content">
            <h3>Traditional Wisdom</h3>
            <p>Our formula is powered by centuries-old secrets. We combine Cumin with Mint for your gut.</p>
            <div style="margin-top:20px; font-weight:700; color:var(--primary);">Cumin • Carom • Black Salt • Mint • Ginger</div>
        </div>
    </section>

    <section class="faq-section">
        <div class="faq-content">
            <h2>FAQ</h2>
            <div class="faq-list">
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Can I use this daily? <span>+</span></div>
                    <div class="faq-answer">Yes, our Phaki is 100% natural and designed for daily digestive support.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Is it suitable for children? <span>+</span></div>
                    <div class="faq-answer">Absolutely, but we recommend half the adult dose for children under 12.</div>
                </div>
            </div>
        </div>
        <div class="faq-image"><img src="{{ 'faq_model.png' | asset_img_url: '800x' }}" alt="FAQ"></div>
    </section>

    <section class="reviews-section">
        <div class="review-card">
            <div class="reviewer-info"><strong>Fatima</strong><br><small>Verified Buyer</small></div>
            <div class="review-content"><div style="color:#333; margin-bottom:10px;">★★★★★</div><p><i>"I've been using it for 2 weeks, and my digestion feels so much better."</i></p></div>
        </div>
    </section>

    <footer>
        <div class="footer-container">
            <div class="footer-brand">
                <h2>NOOR E SHIFA</h2>
                <p>Bringing traditional herbal wisdom to your modern lifestyle.</p>
                <div class="social-links">
                    <a href="#" style="color:white;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path></svg></a>
                </div>
            </div>
            <div class="footer-column"><h3>Shop</h3><ul><li><a href="/collections/all">All Products</a></li></ul></div>
            <div class="footer-column"><h3>Help</h3><ul><li><a href="#">Contact Us</a></li></ul></div>
            <div class="footer-column">
                <h3>Newsletter</h3>
                <form class="newsletter-form"><input type="email" placeholder="Your email"><button type="submit">JOIN</button></form>
            </div>
        </div>
    </footer>
</main>

<script>
    function toggleMenu() { document.getElementById('mobileDrawer').classList.toggle('active'); document.getElementById('overlay').classList.toggle('active'); }
    function toggleAccordion(btn) { btn.parentElement.classList.toggle('active'); btn.querySelector('span').textContent = btn.parentElement.classList.contains('active') ? '-' : '+'; }
    function toggleFaq(el) { const answer = el.nextElementSibling; const span = el.querySelector('span'); if (answer.style.display === 'block') { answer.style.display = 'none'; span.textContent = '+'; } else { answer.style.display = 'block'; span.textContent = '-'; } }
</script>
