{% comment %}
  Noor E Shifa - Product Template
  Converted from static HTML
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b;
        --secondary: #d4a373;
        --accent: #f4f1de;
        --text: #2c3e50;
        --white: #ffffff;
        --border: #e0e0e0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: var(--font-sans);
        color: var(--text);
        background-color: var(--white);
        line-height: 1.6;
    }

    /* Header & Nav */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 5%;
        background-color: var(--white);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        margin: 0 15px;
        letter-spacing: 1px;
    }

    .header-icons {
        display: flex;
        gap: 20px;
    }

    .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        z-index: 1001;
    }

    .menu-toggle span {
        display: block;
        width: 25px;
        height: 2px;
        background-color: var(--primary);
        transition: 0.3s;
    }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        height: 100%;
        background-color: var(--white);
        z-index: 2000;
        transition: 0.4s ease-in-out;
        box-shadow: 10px 0 30px rgba(0,0,0,0.1);
        padding: 40px 30px;
        display: flex;
        flex-direction: column;
    }

    .mobile-drawer.active {
        left: 0;
    }

    .drawer-header {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 40px;
    }

    .close-drawer {
        font-size: 32px;
        cursor: pointer;
        color: var(--primary);
    }

    .drawer-nav {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .drawer-nav a {
        text-decoration: none;
        color: var(--primary);
        font-size: 20px;
        font-family: var(--font-serif);
        font-weight: 700;
        text-transform: uppercase;
    }

    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1999;
        display: none;
    }

    .drawer-overlay.active {
        display: block;
    }

    /* Product Main Section */
    .product-main {
        display: flex;
        padding: 60px 5%;
        gap: 60px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .product-gallery {
        flex: 1.2;
    }

    .main-image {
        width: 100%;
        height: 600px;
        background-color: var(--white);
        border-radius: 8px;
        overflow: hidden;
    }

    .main-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .product-details {
        flex: 1;
    }

    .product-details h1 {
        font-family: var(--font-serif);
        font-size: 48px;
        color: var(--primary);
        line-height: 1.2;
        margin-bottom: 10px;
    }

    .subtitle {
        font-size: 18px;
        color: #666;
        margin-bottom: 20px;
    }

    .description {
        font-size: 16px;
        color: #444;
        margin-bottom: 30px;
        max-width: 500px;
    }

    .price-section {
        margin-bottom: 30px;
    }

    .price {
        font-size: 28px;
        font-weight: 600;
        color: var(--primary);
    }

    .add-to-cart-container {
        margin-bottom: 40px;
    }

    .atc-btn {
        width: 100%;
        background-color: var(--primary);
        color: #FFFFFF !important;
        padding: 18px;
        border: none;
        border-radius: 40px;
        font-weight: 700;
        font-size: 16px;
        text-transform: uppercase;
        cursor: pointer;
        margin-bottom: 20px;
        letter-spacing: 1.5px;
        transition: transform 0.2s, background-color 0.2s;
        box-shadow: 0 4px 15px rgba(26, 59, 43, 0.2);
    }

    .atc-btn:hover {
        transform: translateY(-2px);
        background-color: #244d38;
    }

    /* Accordion Style */
    .accordion {
        border-top: 1px solid var(--border);
    }

    .accordion-item {
        border-bottom: 1px solid var(--border);
    }

    .accordion-header {
        width: 100%;
        padding: 15px 0;
        background: none;
        border: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        cursor: pointer;
        color: var(--primary);
    }

    .accordion-content {
        padding-bottom: 15px;
        font-size: 14px;
        color: #555;
        display: none;
    }

    .accordion-item.active .accordion-content {
        display: block;
    }

    /* Reviews Section */
    .reviews-section {
        padding: 100px 5%;
        background-color: var(--white);
    }

    .review-card {
        display: flex;
        padding: 40px 0;
        border-bottom: 1px solid #eee;
        gap: 40px;
    }

    .reviewer-info {
        width: 150px;
    }

    .review-content {
        flex: 1;
    }

    /* FAQ Section */
    .faq-section {
        display: flex;
        padding: 100px 5%;
        gap: 60px;
        background-color: #faf9f6;
        align-items: center;
    }

    .faq-content {
        flex: 1;
    }

    .faq-content h2 {
        font-family: var(--font-serif);
        font-size: 48px;
        margin-bottom: 40px;
        color: #ccc;
        text-transform: uppercase;
    }

    .faq-list {
        list-style: none;
    }

    .faq-item {
        border-bottom: 1px solid #ddd;
        padding: 20px 0;
    }

    .faq-question {
        width: 100%;
        display: flex;
        justify-content: space-between;
        background: none;
        border: none;
        font-size: 18px;
        font-weight: 600;
        color: var(--primary);
        cursor: pointer;
        text-align: left;
    }

    .faq-answer {
        margin-top: 15px;
        font-size: 15px;
        color: #666;
        display: none;
    }

    .faq-item.active .faq-answer {
        display: block;
    }

    /* Footer */
    footer {
        background-color: var(--primary);
        color: var(--white);
        padding: 80px 5% 40px;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 60px;
    }

    .social-links {
        display: flex;
        gap: 20px;
        margin-top: 20px;
    }

    .newsletter-form {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .newsletter-form input {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 12px;
        border-radius: 40px;
        color: white;
        flex: 1;
        font-size: 14px;
    }

    .newsletter-form button {
        background: var(--white);
        color: var(--primary);
        border: none;
        padding: 12px 25px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
    }

    /* Responsive */
    @media (max-width: 768px) {
        header {
            padding: 15px 5%;
            justify-content: space-between;
            position: relative;
        }
        .menu-toggle {
            display: flex;
        }
        nav {
            display: none;
        }
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 20px;
        }
        .header-icons {
            gap: 15px;
            font-size: 12px;
        }
        .product-main {
            flex-direction: column;
            padding: 30px 5%;
            gap: 30px;
        }
        .main-image {
            height: 350px;
            order: -1;
        }
        .faq-section {
            flex-direction: column;
            padding: 40px 5%;
        }
        .faq-image {
            width: 100%;
            height: 300px;
            order: -1;
        }
        .faq-content h2 {
            font-size: 32px;
        }
        .review-card {
            flex-direction: column;
            gap: 15px;
        }
        .reviewer-info {
            width: 100%;
            display: flex;
            justify-content: space-between;
        }
        .footer-container {
            grid-template-columns: 1fr;
            gap: 30px;
            text-align: center;
        }
        .social-links {
            justify-content: center;
        }
    }
</style>

<header>
    <div class="menu-toggle" onclick="toggleMenu()">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <nav>
        <a href="/">Home</a>
        <a href="/collections/all">Shop</a>
    </nav>
    
    <a href="/" class="logo">NOOR E SHIFA</a>

    <div class="header-icons">
        <a href="/search" style="text-decoration: none; color: var(--primary);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </a>
        <a href="/cart" style="text-decoration: none; color: var(--primary);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            <span style="font-size: 12px; vertical-align: top;">({{ cart.item_count }})</span>
        </a>
    </div>
</header>

<!-- Mobile Drawer -->
<div class="drawer-overlay" id="overlay" onclick="toggleMenu()"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
        <span class="close-drawer" onclick="toggleMenu()">&times;</span>
    </div>
    <nav class="drawer-nav">
        <a href="/" onclick="toggleMenu()">Home</a>
        <a href="/collections/all" onclick="toggleMenu()">Shop</a>
        <a href="/pages/about" onclick="toggleMenu()">About</a>
        <a href="/account" onclick="toggleMenu()">Account</a>
    </nav>
</div>

<main>
    <section class="product-main">
        <div class="product-gallery">
            <div class="main-image">
                <img src="{{ 'Natural Stomach Relief Phaki.png' | asset_img_url: 'master' }}" alt="{{ product.title }}">
            </div>
        </div>

        <div class="product-details">
            <h1>{{ product.title | default: 'Natural Stomach Relief Phaki' }}</h1>
            <p class="subtitle">Complete Digestive Balance</p>
            <p class="description">
                {{ product.description | default: 'A traditional herbal blend designed to provide instant relief from bloating, acidity, and indigestion.' }}
            </p>

            <div class="price-section">
                <span class="price">{{ product.price | money | default: 'Rs. 890.00' }}</span>
            </div>

            <form action="/cart/add" method="post" enctype="multipart/form-data">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit" class="atc-btn">Add to Cart</button>
            </form>
            
            <div class="accordion">
                <div class="accordion-item">
                    <button class="accordion-header" onclick="toggleAccordion(this)">
                        Benefits <span>+</span>
                    </button>
                    <div class="accordion-content">
                        <ul style="padding-left: 20px;">
                            <li>Instant relief from bloating and acidity.</li>
                            <li>Improves overall gut health and metabolism.</li>
                            <li>100% natural and safe for daily use.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="faq-section">
        <div class="faq-content">
            <h2>FAQ</h2>
            <div class="faq-list">
                <div class="faq-item">
                    <button class="faq-question" onclick="toggleFAQ(this)">
                        Can I use this daily? <span>+</span>
                    </button>
                    <div class="faq-answer">
                        Yes, our Phaki is 100% natural and designed for daily digestive support.
                    </div>
                </div>
            </div>
        </div>
        <div class="faq-image">
            <img src="{{ 'faq_model.png' | asset_img_url: 'master' }}" alt="FAQ Support">
        </div>
    </section>
</main>

<footer>
    <div class="footer-container">
        <div class="footer-brand">
            <h2>NOOR E SHIFA</h2>
            <div class="social-links">
                <a href="#" style="color: white; opacity: 0.8; text-decoration: none;">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
            </div>
        </div>
    </div>
</footer>

<script>
    function toggleMenu() {
        const drawer = document.getElementById('mobileDrawer');
        const overlay = document.getElementById('overlay');
        drawer.classList.toggle('active');
        overlay.classList.toggle('active');
    }
    function toggleAccordion(btn) {
        btn.parentElement.classList.toggle('active');
        btn.querySelector('span').textContent = btn.parentElement.classList.contains('active') ? '-' : '+';
    }
    function toggleFAQ(btn) {
        btn.parentElement.classList.toggle('active');
        btn.querySelector('span').textContent = btn.parentElement.classList.contains('active') ? '-' : '+';
    }
</script>
