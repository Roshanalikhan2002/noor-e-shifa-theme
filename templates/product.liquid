<script>
    // === NAV & ACCORDION ===
    function toggleMenu() {
        document.getElementById('mobileDrawer').classList.toggle('active');
        document.getElementById('overlay').classList.toggle('active');
    }
    function toggleAccordion(btn) {
        btn.parentElement.classList.toggle('active');
        btn.querySelector('span').textContent = btn.parentElement.classList.contains('active') ? '-' : '+';
    }
    function toggleFaq(el) {
        const answer = el.nextElementSibling;
        const span = el.querySelector('span');
        if (answer.style.display === 'block') {
            answer.style.display = 'none'; span.textContent = '+';
        } else {
            answer.style.display = 'block'; span.textContent = '-';
        }
    }
    // All cart functions (gOpenCart, gAddToCart, gChangeQty, etc.) are global from theme.liquid
</script>

