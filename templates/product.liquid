{% comment %}
  Noor E Shifa - 100% Fidelity Product Template
  Synced exactly with product-page.html
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b; /* Deep Herbal Green */
        --secondary: #7a1c1c; /* Burgundy/Red */
        --background: #ffffff; /* Pure White */
        --announcement: #333333; /* Charcoal */
        --accent: #E8F3F1;
        --text: #333333;
        --white: #FFFFFF;
        --border: #e0e0e0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--text);
        line-height: 1.6;
    }

    /* Announcement Bar */
    .announcement-bar {
        background-color: var(--announcement);
        color: var(--white);
        text-align: center;
        padding: 8px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Header */
    header {
        background-color: var(--background);
        padding: 20px 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0, 33, 71, 0.1);
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        text-decoration: none;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-weight: 700;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        margin-right: 25px;
        text-transform: uppercase;
    }

    .header-icons { display: flex; gap: 20px; }

    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1001; }
    .menu-toggle span { display: block; width: 25px; height: 2px; background-color: var(--primary); }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 80%; height: 100%;
        background-color: var(--white); z-index: 2000; transition: 0.4s ease-in-out;
        box-shadow: 10px 0 30px rgba(0,0,0,0.1); padding: 40px 30px;
        display: flex; flex-direction: column;
    }
    .mobile-drawer.active { left: 0; }
    .drawer-header { display: flex; justify-content: flex-end; margin-bottom: 40px; }
    .close-drawer { font-size: 32px; cursor: pointer; color: var(--primary); }
    .drawer-nav { display: flex; flex-direction: column; gap: 25px; }
    .drawer-nav a {
        text-decoration: none;
        color: var(--primary);
        font-size: 22px;
        font-family: var(--font-serif);
        font-weight: 700;
        text-transform: uppercase;
        border-bottom: 1px solid rgba(26,59,43,0.1);
        padding-bottom: 15px;
    }
    .drawer-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.5); z-index: 1999; display: none;
    }
    .drawer-overlay.active { display: block; }

    /* Product Main Section */
    .product-main { display: flex; padding: 60px 5%; gap: 60px; max-width: 1400px; margin: 0 auto; }
    .product-gallery { flex: 1.2; }
    .main-image { width: 100%; height: 600px; background-color: var(--white); border-radius: 8px; overflow: hidden; }
    .main-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .mobile-slider { display: none; }

    .product-details { flex: 1; }
    .product-details h1 { font-family: var(--font-serif); font-size: 48px; color: var(--primary); line-height: 1.2; margin-bottom: 10px; }
    .subtitle { font-size: 18px; color: #666; margin-bottom: 20px; }
    .description { font-size: 16px; color: #444; margin-bottom: 30px; max-width: 500px; }
    .price-section { margin-bottom: 30px; }
    .price { font-size: 28px; font-weight: 600; color: var(--primary); }

    .add-to-cart-container { margin-bottom: 40px; }
    .atc-btn {
        width: 100%; background-color: var(--primary); color: #FFFFFF !important;
        padding: 18px; border: none; border-radius: 40px; font-weight: 700;
        font-size: 16px; text-transform: uppercase; cursor: pointer;
        margin-bottom: 20px; letter-spacing: 1.5px;
        transition: transform 0.2s, background-color 0.2s;
        box-shadow: 0 4px 15px rgba(26, 59, 43, 0.2);
    }

    /* Accordion Style */
    .accordion { border-top: 1px solid var(--border); }
    .accordion-item { border-bottom: 1px solid var(--border); }
    .accordion-header {
        width: 100%; padding: 15px 0; background: none; border: none;
        display: flex; justify-content: space-between; align-items: center;
        font-weight: 600; font-size: 14px; text-transform: uppercase;
        cursor: pointer; color: var(--primary);
    }
    .accordion-content { padding-bottom: 15px; font-size: 14px; color: #555; display: none; }
    .accordion-item.active .accordion-content { display: block; }

    /* Spotted on You Section */
    .spotted-section { padding: 80px 5%; text-align: center; background-color: #ffffff; }
    .spotted-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .spotted-item img { width: 100%; border-radius: 8px; transition: transform 0.3s; }

    /* Plate Section */
    .plate-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; }
    .plate-content { flex: 1; }
    .plate-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .plate-image img { width: 100%; height: 100%; object-fit: cover; }
    .plate-table { width: 100%; border-collapse: collapse; margin-top: 30px; }
    .plate-table td { padding: 15px 0; border-bottom: 1px solid #eee; }
    .plate-table td.label { font-weight: 700; color: var(--primary); width: 120px; }

    /* What's Inside */
    .inside-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; background-color: #ffffff; }
    .inside-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .inside-image img { width: 100%; height: 100%; object-fit: cover; }
    .inside-content { flex: 1; }

    /* FAQ */
    .faq-section { display: flex; padding: 100px 5%; gap: 60px; background-color: #faf9f6; align-items: center; }
    .faq-content { flex: 1; }
    .faq-image { flex: 1; border-radius: 12px; overflow: hidden; height: 600px; }
    .faq-image img { width: 100%; height: 100%; object-fit: cover; }
    .faq-item { border-bottom: 1px solid #ddd; padding: 20px 0; }
    .faq-question { font-weight: 600; font-size: 15px; color: #333; display: flex; justify-content: space-between; cursor: pointer; }
    .faq-answer { font-size: 14px; color: #666; display: none; padding-top: 10px; }

    /* Reviews */
    .reviews-section { padding: 100px 5%; background-color: #ffffff; }
    .review-card { display: flex; padding: 40px 0; border-bottom: 1px solid #eee; gap: 40px; }
    .reviewer-info { width: 150px; }
    .reviewer-name { font-weight: 600; font-size: 16px; }
    .verified-badge { font-size: 12px; color: #999; }
    .review-content { flex: 1; }
    .stars { color: #333; font-size: 14px; margin-bottom: 15px; }
    .review-title { font-weight: 700; font-size: 16px; margin-bottom: 10px; }
    .review-text { color: #555; font-size: 15px; font-style: italic; }

    /* Footer */
    footer { background-color: var(--primary); color: var(--white); padding: 80px 5% 40px; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 60px; }
    .footer-brand h2 { font-family: var(--font-serif); margin-bottom: 15px; }
    .footer-brand p { font-size: 14px; opacity: 0.7; }
    .footer-column h3 { font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px; }
    .social-links { display: flex; gap: 20px; margin-top: 20px; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 20px; }
    .newsletter-form input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 40px; color: white; flex: 1; font-size: 14px; }
    .newsletter-form button { background: var(--white); color: var(--primary); border: none; padding: 12px 25px; border-radius: 40px; font-weight: 700; cursor: pointer; }
    .footer-bottom { margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; font-size: 12px; opacity: 0.5; }


    @media (max-width: 768px) {
        .menu-toggle { display: flex !important; }
        header nav { display: none !important; }
        .mobile-drawer nav { display: flex !important; flex-direction: column; }
        header { padding: 12px 5%; }
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 18px;
            white-space: nowrap;
        }
        .header-icons { gap: 12px; }
        .product-main { flex-direction: column; padding: 20px 5%; gap: 20px; }
        .product-gallery { width: 100%; }
        .main-image { display: none !important; }
        .mobile-slider { 
            display: block !important; 
            width: 100%; 
            height: 450px; 
            overflow: hidden; 
            position: relative; 
            border-radius: 12px;
            margin-bottom: 20px;
        }
        .slider-wrapper { 
            display: flex; 
            height: 100%; 
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); 
        }
        .slide { min-width: 100%; height: 100%; }
        .slide img { width: 100%; height: 100%; object-fit: cover; }
        .product-details h1 {
            font-size: 30px;
            line-height: 1.2;
            word-break: normal;
            overflow-wrap: break-word;
        }
        .plate-section, .inside-section, .faq-section { flex-direction: column; padding: 40px 5%; }
        .plate-image, .inside-image, .faq-image { width: 100%; height: 300px; order: -1; }
        .spotted-grid { 
            display: flex; 
            overflow-x: auto; 
            scroll-snap-type: x mandatory; 
            gap: 15px; 
            padding-bottom: 15px;
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .spotted-grid::-webkit-scrollbar { display: none; }
        .spotted-item { 
            flex: 0 0 75%; 
            scroll-snap-align: start;
        }
        .review-card { flex-direction: column; gap: 15px; }
        .reviewer-info { width: 100%; display: flex; justify-content: space-between; align-items: center; }
        .footer-container { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .social-links { justify-content: center; }
        .newsletter-form { flex-direction: column; }
    }
    /* Cart Drawer */
    .cart-drawer-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.5); z-index: 3000; display: none; opacity: 0;
        transition: opacity 0.3s;
    }
    .cart-drawer-overlay.active { display: block; opacity: 1; }

    .cart-drawer {
        position: fixed; top: 0; right: -420px; width: 420px; max-width: 95vw; height: 100%;
        background: var(--white); z-index: 3001;
        box-shadow: -10px 0 40px rgba(0,0,0,0.15);
        display: flex; flex-direction: column;
        transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .cart-drawer.active { right: 0; }

    .cart-drawer-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 25px 30px; border-bottom: 1px solid var(--border);
    }
    .cart-drawer-header h3 { font-family: var(--font-serif); font-size: 22px; color: var(--primary); }
    .cart-close { font-size: 28px; cursor: pointer; color: var(--primary); line-height: 1; background: none; border: none; }

    .cart-drawer-items { flex: 1; overflow-y: auto; padding: 20px 30px; }
    .cart-empty { text-align: center; padding: 60px 0; color: #999; font-size: 15px; }
    .cart-item { display: flex; gap: 16px; padding: 18px 0; border-bottom: 1px solid #f0f0f0; align-items: center; }
    .cart-item-img { width: 80px; height: 80px; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
    .cart-item-img img { width: 100%; height: 100%; object-fit: cover; }
    .cart-item-info { flex: 1; }
    .cart-item-title { font-weight: 600; font-size: 15px; color: var(--primary); margin-bottom: 4px; }
    .cart-item-price { font-size: 14px; color: #666; margin-bottom: 8px; }
    .cart-item-qty { display: flex; align-items: center; gap: 10px; }
    .qty-btn { width: 28px; height: 28px; border: 1px solid var(--border); border-radius: 50%; background: none; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; color: var(--primary); }
    .qty-num { font-weight: 600; font-size: 14px; min-width: 20px; text-align: center; }
    .cart-item-remove { color: #ccc; cursor: pointer; font-size: 20px; background: none; border: none; padding: 4px; }
    .cart-item-remove:hover { color: #999; }

    .cart-drawer-footer { padding: 20px 30px; border-top: 1px solid var(--border); }
    .cart-subtotal { display: flex; justify-content: space-between; font-size: 16px; margin-bottom: 20px; }
    .cart-subtotal span:last-child { font-weight: 700; color: var(--primary); font-size: 18px; }
    .checkout-btn {
        display: block; width: 100%; background: var(--primary); color: white;
        padding: 18px; border: none; border-radius: 40px; font-size: 15px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1.5px; cursor: pointer; text-align: center;
        text-decoration: none; transition: background 0.2s;
    }
    .checkout-btn:hover { background: #244d38; }
    .view-cart-link { display: block; text-align: center; margin-top: 12px; color: #999; font-size: 13px; text-decoration: underline; cursor: pointer; }

    /* Cart success toast */
    .atc-toast {
        position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(80px);
        background: var(--primary); color: white; padding: 14px 28px; border-radius: 40px;
        font-weight: 600; font-size: 14px; z-index: 9999; transition: transform 0.4s ease;
        white-space: nowrap; box-shadow: 0 4px 20px rgba(26,59,43,0.3);
    }
    .atc-toast.show { transform: translateX(-50%) translateY(0); }

    /* Cart count badge */
    .cart-count {
        background: var(--secondary); color: white;
        border-radius: 50%; width: 18px; height: 18px;
        font-size: 11px; font-weight: 700; display: inline-flex;
        align-items: center; justify-content: center;
        vertical-align: super; margin-left: 2px;
    }
</style>


<div class="announcement-bar">Free Shipping on Orders Above Rs. 3000</div>

<header>
    <div class="menu-toggle" onclick="toggleMenu()"><span></span><span></span><span></span></div>
    <nav><a href="/collections/all">Shop</a><a href="#">About</a></nav>
    <a href="/" class="logo">NOOR E SHIFA</a>
    <div class="header-icons">
        <a href="/search" style="color: var(--primary);" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </a>
        <button onclick="gOpenCart()" style="background:none;border:none;cursor:pointer;color:var(--primary);display:flex;align-items:center;gap:4px;padding:0;" aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            <span class="g-cart-count">{{ cart.item_count }}</span>
        </button>
    </div>
</header>

<div class="drawer-overlay" id="overlay" onclick="toggleMenu()"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
        <span class="close-drawer" onclick="toggleMenu()">&times;</span>
    </div>
    <nav class="drawer-nav">
        <a href="/" onclick="toggleMenu()">Home</a>
        <a href="/collections/all" onclick="toggleMenu()">Shop</a>
        <a href="#" onclick="toggleMenu()">About</a>
        <a href="/account" onclick="toggleMenu()">Account</a>
    </nav>
</div>


<main>
    <section class="product-main">
        <div class="product-gallery">
            <div class="main-image">
                <img src="{{ product.featured_image | img_url: '1000x' }}" alt="{{ product.title }}">
            </div>
