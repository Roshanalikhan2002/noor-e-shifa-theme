                <div class="slider-wrapper" id="mobileHeroSlider">
                    <div class="slide"><img src="{{ 'spotted_5.jpg' | asset_img_url: '800x' }}" alt="Slide 1"></div>
                    <div class="slide"><img src="{{ 'spotted_6.jpg' | asset_img_url: '800x' }}" alt="Slide 2"></div>
                    <div class="slide"><img src="{{ 'spotted_4.jpg' | asset_img_url: '800x' }}" alt="Slide 3"></div>
                    <div class="slide"><img src="{{ 'spotted_3.jpg' | asset_img_url: '800x' }}" alt="Slide 4"></div>
                </div>
            </div>
        </div>
        <div class="product-details">
            <h1>{{ product.title }}</h1>
            <p class="subtitle">Complete Digestive Balance</p>
            <div class="description">{{ product.description }}</div>
            <div class="price-section"><span class="price">{{ product.price | money }}</span></div>
            <div class="add-to-cart-container">
                <input type="hidden" id="variantId" value="{{ product.variants.first.id }}">
                <button type="button" class="atc-btn" id="atcBtn"
