{% comment %}
  Noor E Shifa - 100% Fidelity Product Template
  Synced exactly with product-page.html
{% endcomment %}

<style>
    :root {
        --primary: #1a3b2b; /* Deep Herbal Green */
        --secondary: #7a1c1c; /* Burgundy/Red */
        --background: #ffffff; /* Pure White */
        --announcement: #333333; /* Charcoal */
        --accent: #E8F3F1;
        --text: #333333;
        --white: #FFFFFF;
        --border: #e0e0e0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--text);
        line-height: 1.6;
    }

    /* Announcement Bar */
    .announcement-bar {
        background-color: var(--announcement);
        color: var(--white);
        text-align: center;
        padding: 8px 0;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Header */
    header {
        background-color: var(--background);
        padding: 20px 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(0, 33, 71, 0.1);
    }

    .logo {
        font-family: var(--font-serif);
        font-size: 28px;
        color: var(--primary);
        text-decoration: none;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-weight: 700;
        letter-spacing: 2px;
    }

    nav a {
        text-decoration: none;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        margin-right: 25px;
        text-transform: uppercase;
    }

    .header-icons { display: flex; gap: 20px; }

    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1001; }
    .menu-toggle span { display: block; width: 25px; height: 2px; background-color: var(--primary); }

    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 300px; height: 100%;
        background-color: #ffffff; z-index: 2000; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0; display: flex; flex-direction: column;
        box-shadow: 10px 0 40px rgba(0,0,0,0.15);
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-banner {
        background-color: var(--primary);
        padding: 40px 25px;
        color: #FFFFFF;
    }
    .drawer-banner h2 { font-family: var(--font-serif); font-size: 24px; margin: 0; letter-spacing: 1px; }
    .drawer-banner p { font-size: 13px; opacity: 0.8; margin-top: 5px; font-weight: 400; }

    .drawer-nav { 
        padding: 15px 0; 
        flex-grow: 1; 
        overflow-y: auto; 
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        padding: 14px 25px;
        text-decoration: none;
        color: #444;
        font-weight: 600;
        font-size: 15px;
        gap: 20px;
        transition: all 0.2s;
    }
    .drawer-link:hover { 
        background-color: #f9f9f9; 
        color: var(--primary); 
    }
    .drawer-link.active { 
        background-color: #e8f3f1; 
        color: var(--primary); 
    }
    .drawer-link svg { 
        width: 22px; 
        height: 22px; 
        color: #666;
        transition: color 0.2s;
    }
    .drawer-link:hover svg { color: var(--primary); }

    .drawer-divider {
        height: 1px;
        background-color: #eee;
        margin: 10px 0;
    }

    .drawer-group-label {
        padding: 20px 25px 10px;
        font-size: 12px;
        text-transform: uppercase;
        color: #999;
        font-weight: 700;
        letter-spacing: 1.5px;
    }

    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1999;
        display: none;
    }
    .drawer-overlay.active { display: block; }

    /* Product Main Section */
    .product-main { display: flex; padding: 60px 5%; gap: 60px; max-width: 1400px; margin: 0 auto; align-items: flex-start; }
    .product-gallery { flex: 1.2; position: sticky; top: 100px; }
    .main-image { width: 100%; height: 600px; background-color: var(--white); border-radius: 8px; overflow: hidden; }
    .main-image img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .product-details { flex: 1; }
    .product-details h1 { font-family: var(--font-serif); font-size: 48px; color: var(--primary); line-height: 1.2; margin-bottom: 10px; }
    .subtitle { font-size: 18px; color: #666; margin-bottom: 20px; }
    .description { font-size: 16px; color: #444; margin-bottom: 30px; max-width: 500px; }
    .price-section { margin-bottom: 30px; }
    .price { font-size: 28px; font-weight: 600; color: var(--primary); }

    .add-to-cart-container { margin-bottom: 40px; }
    .atc-btn {
        width: 100%; background-color: var(--primary); color: #FFFFFF !important;
        padding: 18px; border: none; border-radius: 40px; font-weight: 700;
        font-size: 16px; text-transform: uppercase; cursor: pointer;
        margin-bottom: 20px; letter-spacing: 1.5px;
        transition: transform 0.2s, background-color 0.2s;
        box-shadow: 0 4px 15px rgba(26, 59, 43, 0.2);
    }

    /* Bundle Selector Styles */
    .bundle-selector {
        margin-bottom: 30px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .bundle-card {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 16px 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
    }
    .bundle-card:hover {
        border-color: var(--primary);
        background: #f9fbf9;
    }
    .bundle-card.selected {
        border-color: var(--primary);
        background: #f1f7f1;
        box-shadow: 0 4px 15px rgba(26, 59, 43, 0.1);
    }
    .bundle-card.selected::after {
        content: '✓';
        position: absolute;
        top: -10px;
        right: -10px;
        background: var(--primary);
        color: white;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        font-weight: bold;
    }
    .bundle-info h4 {
        font-size: 16px;
        color: var(--primary);
        margin-bottom: 4px;
        font-weight: 700;
    }
    .bundle-info p {
        font-size: 13px;
        color: #666;
        margin: 0;
    }
    .bundle-pricing {
        text-align: right;
    }
    .bundle-price {
        display: block;
        font-weight: 700;
        font-size: 16px;
        color: var(--primary);
    }
    .bundle-compare-price {
        display: block;
        font-size: 12px;
        color: #999;
        text-decoration: line-through;
    }
    .popular-badge {
        position: absolute;
        top: -12px;
        left: 20px;
        background: var(--secondary);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .savings-tag {
        color: var(--secondary);
        font-weight: 700;
        font-size: 12px;
        margin-top: 2px;
    }

    /* Accordion Style */
    .accordion { border-top: 1px solid var(--border); }
    .accordion-item { border-bottom: 1px solid var(--border); }
    .accordion-header {
        width: 100%; padding: 15px 0; background: none; border: none;
        display: flex; justify-content: space-between; align-items: center;
        font-weight: 600; font-size: 14px; text-transform: uppercase;
        cursor: pointer; color: var(--primary);
    }
    .accordion-content { padding-bottom: 15px; font-size: 14px; color: #555; display: none; }
    .accordion-item.active .accordion-content { display: block; }

    /* Spotted on You Section */
    .spotted-section { padding: 80px 5%; text-align: left; background-color: #ffffff; }
    .spotted-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
    .spotted-item img { width: 100%; border-radius: 8px; transition: transform 0.3s; }

    /* Plate Section */
    .plate-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; }
    .plate-content { flex: 1; }
    .plate-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .plate-image img { width: 100%; height: 100%; object-fit: cover; }
    .plate-table { width: 100%; border-collapse: collapse; margin-top: 30px; }
    .plate-table td { padding: 15px 0; border-bottom: 1px solid #eee; }
    .plate-table td.label { font-weight: 700; color: var(--primary); width: 120px; }

    /* What's Inside */
    .inside-section { display: flex; padding: 100px 5%; align-items: center; gap: 60px; background-color: #ffffff; }
    .inside-image { flex: 1; border-radius: 12px; overflow: hidden; height: 500px; }
    .inside-image img { width: 100%; height: 100%; object-fit: cover; }
    .inside-content { flex: 1; }

    /* FAQ */
    .faq-section { display: flex; padding: 100px 5%; gap: 60px; background-color: #faf9f6; align-items: center; }
    .faq-content { flex: 1; }
    .faq-image { flex: 1; border-radius: 12px; overflow: hidden; height: 600px; }
    .faq-image img { width: 100%; height: 100%; object-fit: cover; }
    .faq-item { border-bottom: 1px solid #ddd; padding: 20px 0; }
    .faq-question { font-weight: 600; font-size: 15px; color: #333; display: flex; justify-content: space-between; cursor: pointer; }
    .faq-answer { font-size: 14px; color: #666; display: none; padding-top: 10px; }

    /* Reviews */
    .reviews-section { padding: 100px 5%; background-color: #ffffff; }
    .review-card { display: flex; padding: 40px 0; border-bottom: 1px solid #eee; gap: 40px; }
    .reviewer-info { width: 150px; }
    .reviewer-name { font-weight: 600; font-size: 16px; }
    .verified-badge { font-size: 12px; color: #999; }
    .review-content { flex: 1; }
    .stars { color: #333; font-size: 14px; margin-bottom: 15px; }
    .review-title { font-weight: 700; font-size: 16px; margin-bottom: 10px; }
    .review-text { color: #555; font-size: 15px; font-style: italic; }

    /* Footer */
    footer { background-color: var(--primary); color: var(--white); padding: 80px 5% 40px; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 60px; }
    .footer-brand h2 { font-family: var(--font-serif); margin-bottom: 15px; }
    .footer-brand p { font-size: 14px; opacity: 0.7; }
    .footer-column h3 { font-size: 12px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px; }
    .social-links { display: flex; gap: 20px; margin-top: 20px; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 20px; }
    .newsletter-form input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 40px; color: white; flex: 1; font-size: 14px; }
    .newsletter-form button { background: var(--white); color: var(--primary); border: none; padding: 12px 25px; border-radius: 40px; font-weight: 700; cursor: pointer; }
    .footer-bottom { margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; font-size: 12px; opacity: 0.5; }


    @media (max-width: 768px) {
        .menu-toggle { display: flex !important; }
        header nav { display: none !important; }
        .mobile-drawer nav { display: flex !important; flex-direction: column; }
        header { padding: 12px 5%; }
        .logo {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 18px;
            white-space: nowrap;
        }
        .header-icons { gap: 12px; }
        .product-main { flex-direction: column; padding: 20px 5%; gap: 20px; }
        .product-gallery { width: 100%; }
        .main-image { height: 350px; }
        .product-details h1 {
            font-size: 30px;
            line-height: 1.2;
            word-break: normal;
            overflow-wrap: break-word;
        }
        .plate-section, .inside-section, .faq-section { flex-direction: column; padding: 40px 5%; }
        .plate-image, .inside-image, .faq-image { width: 100%; height: 300px; order: -1; }
        .spotted-grid { 
            display: flex; 
            overflow-x: auto; 
            scroll-snap-type: x mandatory; 
            gap: 15px; 
            padding-bottom: 15px;
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .spotted-grid::-webkit-scrollbar { display: none; }
        .spotted-item { 
            flex: 0 0 75%; 
            scroll-snap-align: start;
        }
        .review-card { flex-direction: column; gap: 15px; }
        .reviewer-info { width: 100%; display: flex; justify-content: space-between; align-items: center; }
        .footer-container { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .social-links { justify-content: center; }
        .newsletter-form { flex-direction: column; }
        .product-gallery { position: relative; top: auto; }
    }
    .cart-count {
        background: var(--secondary); color: white;
        border-radius: 50%; width: 18px; height: 18px;
        font-size: 11px; font-weight: 700; display: inline-flex;
        align-items: center; justify-content: center;
        vertical-align: super; margin-left: 2px;
    }
</style>


