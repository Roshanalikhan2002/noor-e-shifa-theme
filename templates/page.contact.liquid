<style>
    :root {
        --primary: #1a3b2b;
        --secondary: #7a1c1c;
        --background: #FAF5EF;
        --white: #FFFFFF;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); background-color: var(--background); color: var(--primary); line-height: 1.6; }

    /* Announcement Bar */
    .announcement-bar {
        background-color: #333;
        color: white;
        text-align: center;
        padding: 8px 0;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Header */
    header {
        background-color: var(--background);
        padding: 20px 5%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(26,59,43,0.1);
    }
    .logo { font-family: var(--font-serif); font-size: 28px; font-weight: 700; text-decoration: none; color: var(--primary); letter-spacing: 2px; }
    nav a { text-decoration: none; color: var(--primary); font-weight: 600; font-size: 14px; margin-right: 25px; text-transform: uppercase; }
    .header-icons { display: flex; gap: 20px; align-items: center; }
    .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .menu-toggle span { display: block; width: 25px; height: 2px; background-color: var(--primary); }

    /* Mobile Drawer */
    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 300px; height: 100%;
        background-color: #ffffff; z-index: 2000; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0; display: flex; flex-direction: column;
        box-shadow: 10px 0 40px rgba(0,0,0,0.15);
    }
    .mobile-drawer.active { left: 0; }
    .drawer-banner { background-color: var(--primary); padding: 40px 25px; color: #FFFFFF; }
    .drawer-banner h2 { font-family: var(--font-serif); font-size: 24px; margin: 0; letter-spacing: 1px; }
    .drawer-banner p { font-size: 13px; opacity: 0.8; margin-top: 5px; font-weight: 400; }
    .drawer-nav { padding: 15px 0; flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; }
    .drawer-link { display: flex; align-items: center; padding: 14px 25px; text-decoration: none; color: #444; font-weight: 600; font-size: 15px; gap: 20px; transition: 0.2s; }
    .drawer-link:hover { background-color: #f9f9f9; color: var(--primary); }
    .drawer-link svg { width: 22px; height: 22px; color: #666; }
    .drawer-divider { height: 1px; background-color: #eee; margin: 10px 0; }
    .drawer-group-label { padding: 20px 25px 10px; font-size: 12px; text-transform: uppercase; color: #999; font-weight: 700; letter-spacing: 1.5px; }
    .drawer-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1999; display: none; }
    .drawer-overlay.active { display: block; }

    /* Contact Section */
    .contact-container { padding: 80px 5%; max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; }
    .contact-info h1 { font-family: var(--font-serif); font-size: 56px; margin-bottom: 20px; line-height: 1.1; }
    .contact-info p { font-size: 18px; color: #444; margin-bottom: 40px; }
    
    .info-item { margin-bottom: 30px; }
    .info-item h3 { font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: #999; margin-bottom: 10px; }
    .info-item p { font-size: 16px; font-weight: 600; color: var(--primary); margin: 0; }

    .contact-form-card {
        background: white;
        padding: 50px;
        border-radius: 20px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.05);
    }
    .form-group { margin-bottom: 25px; }
    .form-group label { display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; color: #666; }
    .form-group input, .form-group textarea {
        width: 100%;
        padding: 15px;
        border: 1px solid #eee;
        border-radius: 8px;
        font-family: inherit;
        font-size: 16px;
        background: #fdfdfd;
        transition: border-color 0.3s;
    }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--primary); }
    
    .submit-btn {
        width: 100%;
        background-color: var(--primary);
        color: white;
        padding: 18px;
        border: none;
        border-radius: 40px;
        font-size: 15px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: opacity 0.3s;
    }
    .submit-btn:hover { opacity: 0.9; }

    /* Footer */
    footer { background-color: var(--primary); color: var(--white); padding: 80px 5% 40px; }
    .footer-container { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px; }
    .footer-brand h2 { font-family: var(--font-serif); font-size: 28px; margin-bottom: 20px; }
    .footer-brand p { font-size: 14px; opacity: 0.7; line-height: 1.7; }
    .social-links { display: flex; gap: 20px; margin-top: 20px; }
    .footer-column h3 { font-size: 12px; text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1px; }
    .footer-column ul { list-style: none; }
    .footer-column ul li { margin-bottom: 12px; }
    .footer-column ul li a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; }
    .newsletter-form { display: flex; gap: 10px; margin-top: 20px; }
    .newsletter-form input { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 40px; color: white; flex: 1; }
    .newsletter-form button { background: var(--white); color: var(--primary); border: none; padding: 12px 25px; border-radius: 40px; font-weight: 700; cursor: pointer; }
    .footer-bottom { margin-top: 60px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; font-size: 12px; opacity: 0.5; }

    @media (max-width: 768px) {
        .menu-toggle { display: flex; }
        header nav { display: none; }
        .contact-container { grid-template-columns: 1fr; gap: 40px; }
        .contact-info h1 { font-size: 40px; }
        .contact-form-card { padding: 30px; }
        .footer-container { grid-template-columns: 1fr; }
    }
</style>

